{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@ds/*": ["../design-system/src/*"]
    }
  },
  "include": ["src", "../design-system/src"],
  "exclude": ["../design-system/src/**/*.stories.tsx", "../design-system/src/**/*.stories.ts"]
}
